POSTGRES_DB=outcomes_annotator
POSTGRES_USER=outcomes_user
POSTGRES_PASSWORD=outcomes_password
DATABASE_URL=postgresql+psycopg://outcomes_user:outcomes_password@postgres:5432/outcomes_annotator
ENVIRONMENT=development
JWT_SECRET_KEY=replace-me-with-long-secret
JWT_REFRESH_SECRET_KEY=replace-me-with-long-refresh-secret
TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=/app/data/uploads
AUDIO_SIGNING_SECRET=replace-me-audio-secret
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080
REDIS_URL=redis://redis:6379/0
JOBS_INLINE=false
LOGIN_RATE_LIMIT_ENABLED=true
